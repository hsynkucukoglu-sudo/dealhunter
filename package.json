{
  "name": "dealhunter-market",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node --watch server.js",
    "dev:frontend": "cd frontend-next && npm run dev",
    "build": "cd frontend-next && npm run build",
    "start": "cd backend && NODE_ENV=production node server.js",
    "start:win": "cd backend && set NODE_ENV=production && node server.js"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "concurrently": "^8.2.2",
    "fluent-ffmpeg": "^2.1.3",
"puppeteer": "^24.43.0"
  }
}
