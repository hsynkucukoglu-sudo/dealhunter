{
  "name": "dealhunter-market",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node --watch server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd backend && NODE_ENV=production node server.js",
    "start:win": "cd backend && set NODE_ENV=production && node server.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
